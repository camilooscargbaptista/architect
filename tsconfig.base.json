{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "composite": true,
    "sourceMap": true,
    "paths": {
      "@girardelli/architect-core/*": ["./packages/architect-core/*"],
      "@girardelli/architect-agents/*": ["./packages/architect-agents/*"]
    }
  }
}
