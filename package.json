{
  "name": "architect-workspace",
  "version": "8.0.0",
  "description": "Genesis: Next-gen autonomous AI coding assistant and architecture analyzer.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf packages/*/dist",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "lint": "eslint packages/*/src --ext .ts",
    "benchmark": "npx tsx packages/architect/src/scripts/benchmark-runner.ts && npx tsx packages/architect/src/scripts/benchmark-report.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/yaml": "^1.9.6",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-morph": "^27.0.2",
    "typescript": "^5.3.0"
  }
}
