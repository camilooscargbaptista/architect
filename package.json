{
  "name": "@girardelli/architect",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered architecture analysis for Claude Code",
  "author": {
    "name": "Camilo Girardelli",
    "email": "contact@girardelli.tech",
    "url": "https://girardelli.tech"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "glob": "^10.3.10",
    "acorn": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  },
  "keywords": [
    "architecture",
    "analysis",
    "Claude Code",
    "plugin",
    "code quality",
    "anti-patterns",
    "refactoring",
    "visualization",
    "dependency graph",
    "mermaid"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/camilogivago/architect"
  },
  "bugs": {
    "url": "https://github.com/camilogivago/architect/issues"
  },
  "homepage": "https://github.com/camilogivago/architect#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
